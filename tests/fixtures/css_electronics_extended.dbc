// Synthetic regression fixture shaped after CSS Electronics J1939 examples.
VERSION "CSS Electronics extended-ID regression"

NS_ :
	NS_DESC_
	CM_
	BA_DEF_
	BA_
	VAL_
	SIG_GROUP_
	SIG_VALTYPE_
	SG_MUL_VAL_

BS_ :

BU_ : EngineECU Logger

BO_ 2364540158 EngineTelemetry: 8 EngineECU
 SG_ EngineSpeed : 0|32@1+ (1,0) [0|0] "rpm" Logger
 SG_ EngineStatus : 32|8@1+ (1,0) [0|3] "" Logger

BO_TX_BU_ 2364540158 : EngineECU,Logger;

CM_ BO_ 2364540158 "Synthetic J1939 engine telemetry";
CM_ SG_ 2364540158 EngineSpeed "Floating-point engine speed";

BA_DEF_ BO_ "VFrameFormat" ENUM "StandardCAN","ExtendedCAN","reserved","J1939PG";
BA_DEF_ SG_ "SPN" INT 0 524287;

BA_ "VFrameFormat" BO_ 2364540158 3;
BA_ "SPN" SG_ 2364540158 EngineSpeed 190;

VAL_ 2364540158 EngineStatus 3 "NotAvailable" 2 "Error" 1 "On" 0 "Off" ;

SIG_GROUP_ 2364540158 EngineSignals 1 : EngineSpeed EngineStatus;

SIG_VALTYPE_ 2364540158 EngineSpeed : 1;
